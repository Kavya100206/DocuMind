# ==============================================
# DOCUMIND ENVIRONMENT CONFIGURATION
# ==============================================
# IMPORTANT: Never commit this file to Git!
# Add your actual values below

# ------------------
# Database Settings
# ------------------
# Your NeonDB connection string
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=your_neondb_connection_string_here

# ------------------
# OpenAI Settings
# ------------------
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ------------------
# Application Settings
# ------------------
DEBUG=True

# ------------------
# Google Drive OAuth2
# ------------------
# Step 1: Go to https://console.cloud.google.com
# Step 2: Create a project → Enable "Google Drive API"
# Step 3: APIs & Services → Credentials → Create OAuth2 Client ID (Web application)
# Step 4: Add http://localhost:8000/auth/google/callback as Authorized Redirect URI
# Step 5: Copy the Client ID and Client Secret below
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
